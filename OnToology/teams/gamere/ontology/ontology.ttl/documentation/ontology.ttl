            rdfs:label "pertenece a" .


###  http://example.org/def/gamere#situadaEn
:situadaEn rdf:type owl:ObjectProperty ;
           rdfs:domain :Praia ;
           rdfs:range :Concello ;
           rdfs:label "situada en" .


