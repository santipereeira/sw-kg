#    Object Properties
#################################################################

###  http://example.org/def/gamere#estaEn
:estaEn rdf:type owl:ObjectProperty ;
        rdfs:domain :Praia ;
        rdfs:range :Ubicacion ;
        rdfs:label "esta en" .


###  http://example.org/def/gamere#perteneceA
:perteneceA rdf:type owl:ObjectProperty ;
            rdfs:domain :Concello ;
