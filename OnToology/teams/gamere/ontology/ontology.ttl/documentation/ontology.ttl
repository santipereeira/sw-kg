<http://example.org/def/gamere#> rdf:type owl:Ontology ;
                                  <http://purl.org/dc/elements/1.1/title> "Ontología de las Playas con bandera azul 2025 de Galicia" ;
                                  <http://purl.org/dc/terms/description> "Ontología diseñada para describir las playas con bandera azul 2025 de Galicia, incluyendo su ubicación, concellos y provincias" ;
                                  rdfs:label "Ontología de las Playas con bandera azul 2025 de Galicia" ;
                                  <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

