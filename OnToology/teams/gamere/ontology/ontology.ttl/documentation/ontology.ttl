###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:DatatypeProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :Concello
                                       :Praia
                                       :Provincia
                                     )
                       ] ;
           rdfs:range xsd:anyURI ;
           rdfs:label "same as" .


