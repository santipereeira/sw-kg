digraph ar2dtool_diagram { 
rankdir=LR;
size="1501"
node [shape = rectangle, color="orange"]; "ns:Distrito" "ns:Campo" "ns:Equipo" "ns:Partido" "ns:Jornada" "ns:Grupo" "ns:Competicion" "ns:Deporte" ; /*classes style*/
	"ns:" -> "https://chowlk.linkeddata.es/" [ label = "mod:createdWith" ];
	"ns:" -> "https://creativecommons.org/licenses/by/4.0/" [ label = "dcterms:license" ];
	"ns:Distrito" -> "xsd:anyURI" [ label = "ns:sameAsDistrito" ];
	"ns:Grupo" -> "xsd:string" [ label = "ns:nombreGrupo" ];
	"ns:Partido" -> "ns:Campo" [ label = "ns:ocurreEn" ];
	"ns:Equipo" -> "xsd:string" [ label = "ns:nombreEquipo" ];
	"ns:Jornada" -> "ns:Partido" [ label = "ns:tienePartido" ];
	"ns:Partido" -> "ns:Equipo" [ label = "ns:tieneEquipoVisitante" ];
	"ns:Competicion" -> "ns:Grupo" [ label = "ns:tieneGrupo" ];
	"ns:Competicion" -> "xsd:string" [ label = "ns:sistemaCompeticion" ];
	"ns:Campo" -> "xsd:integer" [ label = "ns:codigoCampo" ];
	"ns:Grupo" -> "xsd:string" [ label = "ns:categoria" ];
	"ns:Competicion" -> "xsd:string" [ label = "ns:temporada" ];
	"ns:Campo" -> "xsd:float" [ label = "ns:coorX" ];
	"ns:Campo" -> "xsd:float" [ label = "ns:coorY" ];
	"ns:Jornada" -> "xsd:integer" [ label = "ns:codigoJornada" ];
	"ns:Grupo" -> "xsd:string" [ label = "ns:fase" ];
	"ns:Grupo" -> "xsd:string" [ label = "ns:sexo" ];
	"ns:Partido" -> "xsd:integer" [ label = "ns:resultado2" ];
	"ns:Partido" -> "xsd:integer" [ label = "ns:resultado1" ];
	"ns:Partido" -> "xsd:boolean" [ label = "ns:programado" ];
	"ns:Partido" -> "xsd:time" [ label = "ns:hora" ];
	"ns:Campo" -> "xsd:string" [ label = "ns:nombreCampo" ];
	"ns:Distrito" -> "xsd:string" [ label = "ns:nombreDistrito" ];
	"ns:Deporte" -> "xsd:string" [ label = "ns:nombreDeporte" ];
	"ns:Jornada" -> "xsd:date" [ label = "ns:fecha" ];
	"ns:Equipo" -> "xsd:integer" [ label = "ns:codigoEquipo" ];
	"ns:Deporte" -> "xsd:anyURI" [ label = "ns:sameAsDeporte" ];
	"ns:Grupo" -> "ns:Jornada" [ label = "ns:tieneJornada" ];
	"ns:Campo" -> "ns:Distrito" [ label = "ns:localizadoEn" ];
	"ns:Partido" -> "ns:Equipo" [ label = "ns:tieneEquipoLocal" ];
	"ns:Competicion" -> "ns:Deporte" [ label = "ns:tipoDe" ];
	"ns:Partido" -> "xsd:string" [ label = "ns:estado" ];

}
