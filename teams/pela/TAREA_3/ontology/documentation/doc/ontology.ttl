#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#time
xsd:time rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://example.org/partidos/localizadoEn
:localizadoEn rdf:type owl:ObjectProperty ;
              rdfs:domain :Campo ;
              rdfs:range :Distrito ;
              rdfs:comment "Distrito donde está ubicado el campo." ;
              rdfs:label "localizado en" .


###  https://example.org/partidos/ocurreEn
:ocurreEn rdf:type owl:ObjectProperty ;
          rdfs:domain :Partido ;
          rdfs:range :Campo ;
          rdfs:comment "Campo donde se celebra el partido." ;
          rdfs:label "ocurre en" .


###  https://example.org/partidos/tieneEquipoLocal
:tieneEquipoLocal rdf:type owl:ObjectProperty ;
                  rdfs:domain :Partido ;
                  rdfs:range :Equipo ;
                  rdfs:comment "Equipo que juega como local en el partido." ;
                  rdfs:label "tiene equipo local" .


###  https://example.org/partidos/tieneEquipoVisitante
:tieneEquipoVisitante rdf:type owl:ObjectProperty ;
                      rdfs:domain :Partido ;
                      rdfs:range :Equipo ;
                      rdfs:comment "Equipo que juega como visitante en el partido." ;
                      rdfs:label "tiene equipo visitante" .


###  https://example.org/partidos/tieneGrupo
:tieneGrupo rdf:type owl:ObjectProperty ;
            rdfs:domain :Competicion ;
            rdfs:range :Grupo ;
            rdfs:comment "Relaciona una competición con sus grupos." ;
            rdfs:label "tiene grupo" .


###  https://example.org/partidos/tieneJornada
:tieneJornada rdf:type owl:ObjectProperty ;
              rdfs:domain :Grupo ;
              rdfs:range :Jornada ;
              rdfs:comment "Relaciona un grupo con sus jornadas." ;
              rdfs:label "tiene jornada" .


###  https://example.org/partidos/tienePartido
:tienePartido rdf:type owl:ObjectProperty ;
              rdfs:domain :Jornada ;
              rdfs:range :Partido ;
              rdfs:comment "Relaciona una jornada con los partidos que la componen." ;
              rdfs:label "tiene partido" .


###  https://example.org/partidos/tipoDe
:tipoDe rdf:type owl:ObjectProperty ;
        rdfs:domain :Competicion ;
        rdfs:range :Deporte ;
        rdfs:comment "Relaciona una competición con el deporte al que pertenece." ;
        rdfs:label "tipo de" .


#################################################################
#    Data properties
#################################################################

###  https://example.org/partidos/categoria
:categoria rdf:type owl:DatatypeProperty ;
           rdfs:domain :Grupo ;
           rdfs:range xsd:string ;
           rdfs:comment "Categoría de edad o nivel del grupo." ;
           rdfs:label "categoria" .


###  https://example.org/partidos/codigoCampo
:codigoCampo rdf:type owl:DatatypeProperty ;
             rdfs:domain :Campo ;
             rdfs:range xsd:integer ;
             rdfs:comment "Código numérico identificador del campo." ;
             rdfs:label "codigo campo" .


###  https://example.org/partidos/codigoEquipo
:codigoEquipo rdf:type owl:DatatypeProperty ;
              rdfs:domain :Equipo ;
              rdfs:range xsd:integer ;
              rdfs:comment "Código numérico identificador del equipo." ;
              rdfs:label "codigo equipo" .


###  https://example.org/partidos/codigoJornada
:codigoJornada rdf:type owl:DatatypeProperty ;
               rdfs:domain :Jornada ;
               rdfs:range xsd:integer ;
               rdfs:comment "Código numérico identificador de la jornada." ;
               rdfs:label "codigo jornada" .


###  https://example.org/partidos/coorX
:coorX rdf:type owl:DatatypeProperty ;
       rdfs:domain :Campo ;
       rdfs:range xsd:float ;
       rdfs:comment "Coordenada X (longitud) de la ubicación del campo." ;
       rdfs:label "coordenada X" .


###  https://example.org/partidos/coorY
:coorY rdf:type owl:DatatypeProperty ;
       rdfs:domain :Campo ;
       rdfs:range xsd:float ;
       rdfs:comment "Coordenada Y (latitud) de la ubicación del campo." ;
       rdfs:label "coordenada Y" .


###  https://example.org/partidos/estado
:estado rdf:type owl:DatatypeProperty ;
        rdfs:domain :Partido ;
        rdfs:range xsd:string ;
        rdfs:comment "Estado del partido (programado, jugado, suspendido, etc.)." ;
        rdfs:label "estado" .


###  https://example.org/partidos/fase
:fase rdf:type owl:DatatypeProperty ;
      rdfs:domain :Grupo ;
      rdfs:range xsd:string ;
      rdfs:comment "Fase de la competición a la que pertenece el grupo." ;
      rdfs:label "fase" .


###  https://example.org/partidos/fecha
:fecha rdf:type owl:DatatypeProperty ;
       rdfs:domain :Jornada ;
       rdfs:range xsd:date ;
       rdfs:comment "Fecha de celebración de la jornada." ;
       rdfs:label "fecha" .


###  https://example.org/partidos/hora
:hora rdf:type owl:DatatypeProperty ;
      rdfs:domain :Partido ;
      rdfs:range xsd:time ;
      rdfs:comment "Hora de inicio del partido." ;
      rdfs:label "hora" .


###  https://example.org/partidos/nombreCampo
:nombreCampo rdf:type owl:DatatypeProperty ;
             rdfs:domain :Campo ;
             rdfs:range xsd:string ;
             rdfs:comment "Nombre de la instalación deportiva." ;
             rdfs:label "nombre campo" .


###  https://example.org/partidos/nombreDeporte
:nombreDeporte rdf:type owl:DatatypeProperty ;
               rdfs:domain :Deporte ;
               rdfs:range xsd:string ;
               rdfs:comment "Nombre del deporte." ;
               rdfs:label "nombre deporte" .


###  https://example.org/partidos/nombreDistrito
:nombreDistrito rdf:type owl:DatatypeProperty ;
                rdfs:domain :Distrito ;
                rdfs:range xsd:string ;
                rdfs:comment "Nombre del distrito." ;
                rdfs:label "nombre distrito" .


###  https://example.org/partidos/nombreEquipo
:nombreEquipo rdf:type owl:DatatypeProperty ;
              rdfs:domain :Equipo ;
              rdfs:range xsd:string ;
              rdfs:comment "Nombre del equipo." ;
              rdfs:label "nombre equipo" .


###  https://example.org/partidos/nombreGrupo
:nombreGrupo rdf:type owl:DatatypeProperty ;
             rdfs:domain :Grupo ;
             rdfs:range xsd:string ;
             rdfs:comment "Nombre del grupo dentro de la competición." ;
             rdfs:label "nombre grupo" .


###  https://example.org/partidos/programado
:programado rdf:type owl:DatatypeProperty ;
            rdfs:domain :Partido ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indica si el partido está programado (true) o no (false)." ;
            rdfs:label "programado" .


###  https://example.org/partidos/resultado1
:resultado1 rdf:type owl:DatatypeProperty ;
            rdfs:domain :Partido ;
            rdfs:range xsd:integer ;
            rdfs:comment "Goles o puntos del equipo local." ;
            rdfs:label "resultado1" .


###  https://example.org/partidos/resultado2
:resultado2 rdf:type owl:DatatypeProperty ;
            rdfs:domain :Partido ;
            rdfs:range xsd:integer ;
            rdfs:comment "Goles o puntos del equipo visitante." ;
            rdfs:label "resultado2" .


###  https://example.org/partidos/sameAsDeporte
:sameAsDeporte rdf:type owl:DatatypeProperty ;
               rdfs:domain :Deporte ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "URI externa equivalente para el deporte (enlace a recurso LOD)." ;
               rdfs:label "same as deporte" .


###  https://example.org/partidos/sameAsDistrito
:sameAsDistrito rdf:type owl:DatatypeProperty ;
                rdfs:domain :Distrito ;
                rdfs:range xsd:anyURI ;
                rdfs:comment "URI externa equivalente para el distrito (enlace a recurso LOD)." ;
                rdfs:label "same as distrito" .


###  https://example.org/partidos/sexo
:sexo rdf:type owl:DatatypeProperty ;
      rdfs:domain :Grupo ;
      rdfs:range xsd:string ;
      rdfs:comment "Categoría de sexo del grupo (masculino, femenino, mixto)." ;
      rdfs:label "sexo" .


###  https://example.org/partidos/sistemaCompeticion
:sistemaCompeticion rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Competicion ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Sistema de competición (liga, copa, liguilla, etc.)." ;
                    rdfs:label "sistema competicion" .


###  https://example.org/partidos/temporada
:temporada rdf:type owl:DatatypeProperty ;
           rdfs:domain :Competicion ;
           rdfs:range xsd:string ;
           rdfs:comment "Temporada en formato texto (p. ej. 2014/2015)." ;
           rdfs:label "temporada" .


#################################################################
#    Classes
#################################################################

###  https://example.org/partidos/Campo
:Campo rdf:type owl:Class ;
       rdfs:comment "Instalación deportiva donde se celebran los partidos." ;
       rdfs:label "Campo" .


###  https://example.org/partidos/Competicion
:Competicion rdf:type owl:Class ;
             rdfs:comment "Competición deportiva organizada dentro de un deporte y temporada." ;
             rdfs:label "Competicion" .


###  https://example.org/partidos/Deporte
:Deporte rdf:type owl:Class ;
         rdfs:comment "Representa un deporte (p. ej. fútbol, baloncesto)." ;
         rdfs:label "Deporte" .


###  https://example.org/partidos/Distrito
:Distrito rdf:type owl:Class ;
          rdfs:comment "Distrito o zona geográfica donde está ubicado un campo." ;
          rdfs:label "Distrito" .


###  https://example.org/partidos/Equipo
:Equipo rdf:type owl:Class ;
        rdfs:comment "Equipo participante en la competición." ;
        rdfs:label "Equipo" .


###  https://example.org/partidos/Grupo
:Grupo rdf:type owl:Class ;
       rdfs:comment "Grupo o categoría dentro de una competición." ;
       rdfs:label "Grupo" .


###  https://example.org/partidos/Jornada
:Jornada rdf:type owl:Class ;
         rdfs:comment "Jornada de una competición, identificada por código y fecha." ;
         rdfs:label "Jornada" .


###  https://example.org/partidos/Partido
:Partido rdf:type owl:Class ;
         rdfs:comment "Encuentro deportivo entre dos equipos en un campo y fecha determinados." ;
         rdfs:label "Partido" .


