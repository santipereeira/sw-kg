@prefix : <https://example.org/partidos/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://example.org/partidos/> .

<https://example.org/partidos/> rdf:type owl:Ontology ;
                                 <http://purl.org/dc/terms/creator> "Santiago Pereira Olmeda, Mateo Fraguas Abal, Gonzalo Landeira Rodríguez" ;
                                 <http://purl.org/dc/terms/description> "Ontología para la gestión de competiciones deportivas, incluyendo partidos, equipos, campos, grupos y jornadas." ;
                                 <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                 <http://purl.org/dc/terms/title> "Ontología Deportes" ;
                                 owl:versionInfo "1.0.0" ;
                                 <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

