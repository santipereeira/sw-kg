:Fase a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#codigoFase> ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#nombreFase> ],
        [ a sh:PropertyShape ;
