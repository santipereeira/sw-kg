            sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass <http://example.org/def/juegosdeportivosmunicipalesmadrid#Fase> .

:Grupo a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#nombreGrupo> ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#codigoGrupo> ],
        [ a sh:PropertyShape ;
            sh:in ( <http://example.org/def/juegosdeportivosmunicipalesmadrid#Grupo> ) ;
            sh:maxCount 1 ;
