    sh:targetClass <http://example.org/def/juegosdeportivosmunicipalesmadrid#Grupo> .

:Temporada a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:in ( <http://example.org/def/juegosdeportivosmunicipalesmadrid#Temporada> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#nombreTemporada> ] ;
    sh:targetClass <http://example.org/def/juegosdeportivosmunicipalesmadrid#Temporada> .

:Equipo a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:in ( <http://example.org/def/juegosdeportivosmunicipalesmadrid#Equipo> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#codigoEquipo> ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path <http://example.org/def/juegosdeportivosmunicipalesmadrid#nombreEquipo> ] ;
