		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "hora";
			rr:datatype xsd:time
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:programado;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "programado";
			rr:datatype xsd:integer
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:resultadoLocal;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "resultadoLocal";
			rr:datatype xsd:integer
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:resultadoVisitante;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "resultadoVisitante";
			rr:datatype xsd:integer
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:estado;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "estado";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:tieneEquipoLocal;
		];
		rr:objectMap [
			a rr:RefObjectMap;
			rr:parentTriplesMap <EQUIPO_0>;
			rr:joinCondition [
				rr:child "codigoEquipoLocal";
				rr:parent "codigoEquipo";
			];
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:tieneEquipoVisitante;
		];
		rr:objectMap [
			a rr:RefObjectMap;
			rr:parentTriplesMap <EQUIPO_0>;
			rr:joinCondition [
				rr:child "codigoEquipoVisitante";
				rr:parent "codigoEquipo";
			];
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:perteneceAGrupo;
		];
		rr:objectMap [
			a rr:RefObjectMap;
			rr:parentTriplesMap <GRUPO_0>;
			rr:joinCondition [
				rr:child "codigoGrupo";
				rr:parent "codigoGrupo";
			];
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant ta:perteneceAFase;
		];
		rr:objectMap [
			a rr:RefObjectMap;
			rr:parentTriplesMap <FASE_0>;
			rr:joinCondition [
				rr:child "codigoFase";
