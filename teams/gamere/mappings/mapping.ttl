 rr:class :Provincia
];

rr:predicateObjectMap [
 rr:predicate :nameProvincia ;
 rr:objectMap [ rml:reference "PROVINCIA" ]
];

rr:predicateObjectMap [
 rr:predicate owl:sameAs ;
 rr:objectMap [
  rr:template "https://www.wikidata.org/entity/{wikidata_provincia}" ;
  rr:termType rr:IRI
 ]
];

rr:predicateObjectMap [
 rr:predicate :codigoProvincia ;
 rr:objectMap [
