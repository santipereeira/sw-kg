@prefix gamere: <http://example.org/def/gamere#>.
@prefix res: <http://example.org/resource/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix formats: <http://www.w3.org/ns/formats/>.
@prefix comp: <http://semweb.mmlab.be/ns/rml-compression#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@base <http://example.com/ns#>.


<playas_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "data/PraiasBandeiraAzul-2025-csv.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://example.org/resource/praia/{CODIGO_CONCELLO}_{PRAIA}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant gamere:Praia;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:nomePraia;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "PRAIA";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:lonxitude;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "LONXITUDE";
			rr:datatype xsd:integer
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:entorno;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "TIPO";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:tipoArena;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "TIPO_DE_AREA";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:url;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "MAIS_INFORMACION_EN_TURGALICIA";
			rr:datatype xsd:anyURI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant owl:sameAs;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "https://www.wikidata.org/entity/{wikidata_praia}";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:situadaEn;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://example.org/resource/concello/{CODIGO_CONCELLO}";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gamere:estaEn;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://example.org/resource/ubicacion/{Coordenada_X}_{Coordenada_Y}";
		];
	].


