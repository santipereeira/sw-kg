@prefix gamere: <http://example.org/def/gamere#> .
@base <http://example.org/def/gamere#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

<http://example.org/def/gamere#> rdf:type owl:Ontology ;
    rdfs:label "Ontología de las Playas con bandera azul 2025 de Galicia" ;
    dc:title "Ontología de las Playas con bandera azul 2025 de Galicia" ;
    dcterms:description "Ontología diseñada para describir las playas con bandera azul 2025 de Galicia, incluyendo su ubicación, concellos y provincias" ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

#################################################################
#    Annotation properties
#################################################################



###  https://w3id.org/mod#createdWith
mod:createdWith rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/def/gamere#estaEn
gamere:estaEn rdf:type owl:ObjectProperty ;
              rdfs:domain gamere:Praia ;
              rdfs:range gamere:Ubicacion ;
              rdfs:label "esta en" .


###  http://example.org/def/gamere#perteneceA
gamere:perteneceA rdf:type owl:ObjectProperty ;
                  rdfs:domain gamere:Concello ;
                  rdfs:range gamere:Provincia ;
                  rdfs:label "pertenece a" .


###  http://example.org/def/gamere#situadaEn
gamere:situadaEn rdf:type owl:ObjectProperty ;
                 rdfs:domain gamere:Praia ;
                 rdfs:range gamere:Concello ;
                 rdfs:label "situada en" .


#################################################################
#    Data properties
#################################################################

###  http://example.org/def/gamere#codigoConcello
gamere:codigoConcello rdf:type owl:DatatypeProperty ;
                      rdfs:domain gamere:Concello ;
                      rdfs:range xsd:integer ;
                      rdfs:label "codigo concello" .


###  http://example.org/def/gamere#codigoProvincia
gamere:codigoProvincia rdf:type owl:DatatypeProperty ;
                       rdfs:domain gamere:Provincia ;
                       rdfs:range xsd:integer ;
                       rdfs:label "codigo provincia" .


###  http://example.org/def/gamere#coordenadasX
gamere:coordenadasX rdf:type owl:DatatypeProperty ;
                    rdfs:domain gamere:Ubicacion ;
                    rdfs:range xsd:float ;
                    rdfs:label "coordenadas x" .


###  http://example.org/def/gamere#coordenadasY
gamere:coordenadasY rdf:type owl:DatatypeProperty ;
                    rdfs:domain gamere:Ubicacion ;
                    rdfs:range xsd:float ;
                    rdfs:label "coordenadas y" .


###  http://example.org/def/gamere#descripcion
gamere:descripcion rdf:type owl:DatatypeProperty ;
                   rdfs:domain gamere:Ubicacion ;
                   rdfs:range xsd:string ;
                   rdfs:label "descripcion" .


###  http://example.org/def/gamere#entorno
gamere:entorno rdf:type owl:DatatypeProperty ;
               rdfs:domain gamere:Praia ;
               rdfs:range xsd:string ;
               rdfs:label "entorno" .


###  http://example.org/def/gamere#lonxitude
gamere:lonxitude rdf:type owl:DatatypeProperty ;
                 rdfs:domain gamere:Praia ;
                 rdfs:range xsd:integer ;
                 rdfs:label "lonxitude" .


###  http://example.org/def/gamere#nameConcello
gamere:nameConcello rdf:type owl:DatatypeProperty ;
                    rdfs:domain gamere:Concello ;
                    rdfs:range xsd:string ;
                    rdfs:label "name concello" .


###  http://example.org/def/gamere#nameProvincia
gamere:nameProvincia rdf:type owl:DatatypeProperty ;
                     rdfs:domain gamere:Provincia ;
                     rdfs:range xsd:string ;
                     rdfs:label "name provincia" .


###  http://example.org/def/gamere#nomePraia
gamere:nomePraia rdf:type owl:DatatypeProperty ;
                 rdfs:domain gamere:Praia ;
                 rdfs:range xsd:string ;
                 rdfs:label "nome praia" .


###  http://example.org/def/gamere#tipoArena
gamere:tipoArena rdf:type owl:DatatypeProperty ;
                 rdfs:domain gamere:Praia ;
                 rdfs:range xsd:string ;
                 rdfs:label "tipo arena" .


###  http://example.org/def/gamere#url
gamere:url rdf:type owl:DatatypeProperty ;
           rdfs:domain gamere:Praia ;
           rdfs:range xsd:anyURI ;
           rdfs:label "url" .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:DatatypeProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( gamere:Concello
                                       gamere:Praia
                                       gamere:Provincia
                                     )
                       ] ;
           rdfs:range xsd:anyURI ;
           rdfs:label "same as" .


