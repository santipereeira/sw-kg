@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix mod: <https://w3id.org/mod#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ta: <http://example.org/def/teatrosyauditorios#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ta:CP a owl:DatatypeProperty ;
    rdfs:label "c p" ;
    rdfs:domain ta:Enderezo .

ta:aforamiento a owl:DatatypeProperty ;
    rdfs:label "aforamiento" ;
    rdfs:domain ta:Espazo .

ta:calle a owl:DatatypeProperty ;
    rdfs:label "calle" ;
    rdfs:domain ta:Enderezo ;
    rdfs:range xsd:string .

ta:email a owl:DatatypeProperty ;
    rdfs:label "email" ;
    rdfs:domain ta:DatoContacto .

ta:estaen a owl:ObjectProperty ;
    rdfs:label "estaen" ;
    rdfs:domain ta:Espazo ;
    rdfs:range ta:Enderezo .

ta:label a owl:DatatypeProperty ;
    rdfs:label "label" ;
    rdfs:domain ta:Espazo .

ta:latitud a owl:DatatypeProperty ;
    rdfs:label "latitud" ;
    rdfs:domain ta:Enderezo .

ta:longitud a owl:DatatypeProperty ;
    rdfs:label "longitud" ;
    rdfs:domain ta:Enderezo .

ta:nombre a owl:DatatypeProperty ;
    rdfs:label "nombre" ;
    rdfs:domain ta:Concello,
        ta:Provincia ;
    rdfs:range xsd:string .

ta:numero a owl:DatatypeProperty ;
    rdfs:label "numero" ;
    rdfs:domain ta:Enderezo .

ta:pertenece a owl:ObjectProperty ;
    rdfs:label "pertenece" ;
    rdfs:domain ta:Enderezo ;
    rdfs:range ta:Concello .

ta:telefono a owl:DatatypeProperty ;
    rdfs:label "telefono" ;
    rdfs:domain ta:DatoContacto ;
    rdfs:range xsd:integer .

ta:tiene a owl:ObjectProperty ;
    rdfs:label "tiene" ;
    rdfs:domain ta:Espazo ;
    rdfs:range ta:DatoContacto .

ta:ubicadoen a owl:ObjectProperty ;
    rdfs:label "ubicadoen" ;
    rdfs:domain ta:Concello ;
    rdfs:range ta:Provincia .

ta:web a owl:DatatypeProperty ;
    rdfs:label "web" ;
    rdfs:domain ta:DatoContacto .

dcterms:created a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:description a owl:AnnotationProperty .

dcterms:license a owl:AnnotationProperty .

dcterms:title a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

owl:priorVersion a owl:AnnotationProperty .

owl:versionIRI a owl:AnnotationProperty .

owl:versionInfo a owl:AnnotationProperty .

<https://w3id.org/example#> a owl:Ontology ;
    dcterms:created "2026-03-05"^^xsd:date ;
    dcterms:creator "Óscar Padín Devesa, Pablo Pérez Rodríguez, Jaime Zapico López" ;
    dcterms:description "Ontología basada en datos recogidos de localizacion y datos de contacto de teatros y auditorios en la comunidad autónoma de Galicia."@es ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "Teatros y Auditorios en Galicia"@es ;
    vann:preferredNamespacePrefix "choosenprefix" ;
    vann:preferredNamespaceUri <https://w3id.org/example#> ;
    owl:priorVersion <https://w3id.org/example/1.0.0> ;
    owl:versionIRI <https://w3id.org/example/1.0.1> ;
    owl:versionInfo "0.0.1" ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

ta:Provincia a owl:Class ;
    rdfs:label "Provincia" .

ta:Concello a owl:Class ;
    rdfs:label "Concello" .

ta:DatoContacto a owl:Class ;
    rdfs:label "Dato Contacto" .

ta:Espazo a owl:Class ;
    rdfs:label "Espazo" .

ta:Enderezo a owl:Class ;
    rdfs:label "Enderezo" .

