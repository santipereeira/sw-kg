@prefix : <http://weso.es/shapes/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ta: <http://example.org/def/teatrosyauditorios#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Espazo a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node :Enderezo ;
            sh:path ta:estaen ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:label ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node :DatoContacto ;
            sh:path ta:tiene ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:aforamiento ],
        [ a sh:PropertyShape ;
            sh:in ( ta:Espazo ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass ta:Espazo .

:Concello a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:in ( ta:Concello ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:nombre ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node :Provincia ;
            sh:path ta:ubicadoen ] ;
    sh:targetClass ta:Concello .

:DatoContacto a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:email ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:telefono ],
        [ a sh:PropertyShape ;
            sh:in ( ta:DatoContacto ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:web ] ;
    sh:targetClass ta:DatoContacto .

:Enderezo a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:in ( ta:Enderezo ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:longitud ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node :Concello ;
            sh:path ta:pertenece ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:CP ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:calle ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:latitud ] ;
    sh:targetClass ta:Enderezo .

:Provincia a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path ta:nombre ],
        [ a sh:PropertyShape ;
            sh:in ( ta:Provincia ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass ta:Provincia .

