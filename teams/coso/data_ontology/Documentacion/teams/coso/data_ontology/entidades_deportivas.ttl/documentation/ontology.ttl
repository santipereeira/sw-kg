###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty .


###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/def/dep#dataAlta
:dataAlta rdf:type owl:ObjectProperty ;
          rdfs:domain :Equipo ;
          rdfs:range xsd:Date .


###  http://example.org/def/dep#estaEn
:estaEn rdf:type owl:ObjectProperty ;
        rdfs:domain :Concello ,
                    :Enderezo ;
        rdfs:range :Concello ,
                   :Provincia ;
        rdfs:label "esta en" .


###  http://example.org/def/dep#nif
:nif rdf:type owl:ObjectProperty ;
     rdfs:domain :Equipo ;
     rdfs:range xsd:String .


###  http://example.org/def/dep#nome
:nome rdf:type owl:ObjectProperty ;
      rdfs:domain :Equipo ;
      rdfs:range xsd:String .


###  http://example.org/def/dep#nomeEspecialidade
:nomeEspecialidade rdf:type owl:ObjectProperty ;
                   rdfs:domain :Especialidade ;
                   rdfs:range xsd:String .


###  http://example.org/def/dep#nomeRua
:nomeRua rdf:type owl:ObjectProperty ;
         rdfs:domain :Enderezo ;
         rdfs:range xsd:str .


###  http://example.org/def/dep#paxinaWeb
:paxinaWeb rdf:type owl:ObjectProperty ;
           rdfs:domain :Concello ,
                       :Deporte ,
                       :Equipo ,
                       :Provincia ;
           rdfs:range xsd:String .


###  http://example.org/def/dep#resideEn
:resideEn rdf:type owl:ObjectProperty ;
          rdfs:domain :Equipo ;
          rdfs:range :Enderezo ;
          rdfs:label "reside en" .


###  http://example.org/def/dep#tipoEntidade
:tipoEntidade rdf:type owl:ObjectProperty ;
              rdfs:domain :Equipo ;
              rdfs:range xsd:String .


###  http://example.org/def/dep#xoga
:xoga rdf:type owl:ObjectProperty ;
      rdfs:domain :Equipo ;
      rdfs:range :Deporte ;
      rdfs:label "xoga" .


#################################################################
#    Data properties
#################################################################

###  http://example.org/def/dep#codProvincia
:codProvincia rdf:type owl:DatatypeProperty ;
              rdfs:domain :Provincia ;
              rdfs:range xsd:int ;
              rdfs:label "cod provincia" .


###  http://example.org/def/dep#codigoConcello
:codigoConcello rdf:type owl:DatatypeProperty ;
                rdfs:domain :Concello ;
                rdfs:label "codigo concello" .


###  http://example.org/def/dep#codigoPostal
:codigoPostal rdf:type owl:DatatypeProperty ;
              rdfs:domain :Enderezo ;
              rdfs:label "codigo postal" .


###  http://example.org/def/dep#dataAlta
:dataAlta rdf:type owl:DatatypeProperty .


###  http://example.org/def/dep#nif
:nif rdf:type owl:DatatypeProperty .


###  http://example.org/def/dep#nome
:nome rdf:type owl:DatatypeProperty .


###  http://example.org/def/dep#nomeEspecialidade
:nomeEspecialidade rdf:type owl:DatatypeProperty .


###  http://example.org/def/dep#nomeRua
:nomeRua rdf:type owl:DatatypeProperty .


###  http://example.org/def/dep#numero
:numero rdf:type owl:DatatypeProperty ;
        rdfs:domain :Equipo ;
        rdfs:range xsd:int ;
        rdfs:label "numero" .


###  http://example.org/def/dep#paxinaWeb
:paxinaWeb rdf:type owl:DatatypeProperty .


###  http://example.org/def/dep#telefono
:telefono rdf:type owl:DatatypeProperty ;
          rdfs:domain :Equipo ;
          rdfs:range xsd:int ;
          rdfs:label "telefono" .


###  http://example.org/def/dep#tipoEntidade
:tipoEntidade rdf:type owl:DatatypeProperty .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:DatatypeProperty ;
           rdfs:domain :Concello ,
                       :Deporte ,
                       :Provincia ;
           rdfs:range xsd:anyURI ;
           rdfs:label "same as" .


#################################################################
#    Classes
#################################################################

###  http://example.org/def/dep#Concello
:Concello rdf:type owl:Class ;
          rdfs:label "Concello" .


###  http://example.org/def/dep#Deporte
:Deporte rdf:type owl:Class ;
         rdfs:subClassOf :Especialidade ;
         rdfs:label "Deporte" .


###  http://example.org/def/dep#Enderezo
:Enderezo rdf:type owl:Class ;
          rdfs:label "Enderezo" .


###  http://example.org/def/dep#Equipo
:Equipo rdf:type owl:Class ;
        rdfs:label "Equipo" .


###  http://example.org/def/dep#Especialidade
:Especialidade rdf:type owl:Class ;
               rdfs:label "Especialidade" .


###  http://example.org/def/dep#Provincia
:Provincia rdf:type owl:Class ;
           rdfs:label "Provincia" .


###  http://www.w3.org/2001/XMLSchema#Date
xsd:Date rdf:type owl:Class .


###  http://www.w3.org/2001/XMLSchema#String
xsd:String rdf:type owl:Class .


###  http://www.w3.org/2001/XMLSchema#str
xsd:str rdf:type owl:Class .


