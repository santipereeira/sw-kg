@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/def/dep#> .

<http://example.org/def/dep#> rdf:type owl:Ontology ;
                               <http://purl.org/dc/elements/1.1/creator> "Yara Costas, Livia Xavier, Daniel Souto" ;
                               <http://purl.org/dc/elements/1.1/title> "Entidades deportivas" ;
