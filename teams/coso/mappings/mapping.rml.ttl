@prefix dep: <http://example.org/def/dep#>.
@prefix res: <http://example.org/resource/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix formats: <http://www.w3.org/ns/formats/>.
@prefix comp: <http://semweb.mmlab.be/ns/rml-compression#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@base <http://example.com/ns#>.


<equipos_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "clean_entidades_deportivas.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://example.org/resource/equipo/{nome}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant dep:Equipo;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:nome;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "nome";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:tipoEntidade;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "tipo_entidade";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:telefono1;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "telefono1";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:telefono2;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "telefono2";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:nif;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "nif";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:dataAlta;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "data_alta";
			rr:datatype xsd:date
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:paxinaWeb;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "web";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:numero;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "numero";
			rr:datatype xsd:str
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:xoga;
		];
		rr:objectMap [
			a rr:RefObjectMap;
			rr:parentTriplesMap <deporte_0>;

		]
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dep:resideEn;
		];
		rr:objectMap [
			a rr:RefObjectMap;
			rr:parentTriplesMap <enderezo_0>;

		]
	].


